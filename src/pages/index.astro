---
import '../styles/global.css';

const businessName = "Nombre del Cliente";
const whatsapp = "50499999999";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Cobertura profesional de eventos con fotografía, video y contenido publicitario para redes sociales."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{businessName} | Eventos</title>
  </head>

  <body>
    <main class="ss-page">
      <section class="ss-hero">
        <div class="ss-hero-glow ss-hero-glow-one"></div>
        <div class="ss-hero-glow ss-hero-glow-two"></div>

        <nav class="ss-navbar">
          <a href="#" class="ss-brand">
            <span class="ss-brand-mark">EG</span>
            <span class="ss-brand-text">Eventos</span>
          </a>

          <div class="ss-nav-links">
            <a href="#servicios">Servicios</a>
            <a href="#galeria">Galería</a>
            <a href="#contacto">Contacto</a>
          </div>

          <a href={`https://wa.me/${whatsapp}`} class="ss-button ss-button-primary ss-nav-cta">
            Cotizar evento
          </a>
        </nav>

        <div class="ss-hero-grid">
          <div class="ss-hero-content">
            <p class="ss-eyebrow">Wedding Events Planners</p>

            <h1 class="ss-display-title ss-hero-title">
              Hacemos de cada evento un recuerdo inolvidable.
            </h1>

            <p class="ss-body-text ss-hero-text">
              Diseñamos, decoramos y coordinamos eventos con estilo y elegancia.
              Bodas, graduaciones, baby showers, cumpleaños y celebraciones especiales
              creadas con atención a cada detalle.
            </p>

            <div class="ss-hero-actions">
              <a href={`https://wa.me/${whatsapp}`} class="ss-button ss-button-primary">
                Cotizar con nosotros
              </a>

              <a href="#servicios" class="ss-button ss-button-secondary">
                Ver servicios
              </a>
            </div>

            <div class="ss-hero-meta">
              <div>
                <strong>Eventos</strong>
                <span>sociales y elegantes</span>
              </div>

              <div>
                <strong>Decoración</strong>
                <span>personalizada</span>
              </div>

              <div>
                <strong>Detalles</strong>
                <span>con estilo</span>
              </div>
            </div>
          </div>

          <div class="ss-hero-visual">
            <div class="ss-hero-frame">
              <div class="ss-hero-image">
                <div class="ss-hero-badge">
                  <span>Nuestra pasión</span>
                  <strong>Tu satisfacción</strong>
                </div>
              </div>
            </div>

            <div class="ss-floating-card ss-floating-card-one">
              <span>Bodas</span>
            </div>

            <div class="ss-floating-card ss-floating-card-two">
              <span>Graduaciones</span>
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
    </main>
  </body>
</html>