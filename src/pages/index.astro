---
import '@fontsource-variable/cormorant-garamond/index.css';
import '@fontsource-variable/cormorant-garamond/wght-italic.css';
import '@fontsource-variable/inter/index.css';
import '../styles/global.css';

const businessName = "EG Eventos";
const whatsapp = "50489123226";
const phone = "8912-3226";
const email = "eventos.eg@hotmail.com";
const instagram = "https://www.instagram.com/egeventos01";
const facebook = "https://www.facebook.com/egevetos";
const whatsappMsg = "Hola EG Eventos, vi su página y me gustaría cotizar un evento.";
const whatsappLink = `https://wa.me/${whatsapp}?text=${encodeURIComponent(whatsappMsg)}`;

const siteUrl = "https://egeventoshn.com";
const pageTitle = "EG Eventos | Wedding & Events Planners en Tegucigalpa";
const pageDesc =
  "Planificación, decoración y coordinación de bodas, graduaciones y celebraciones sociales en Tegucigalpa y todo Honduras. Cuidamos cada detalle de tu evento.";
const ogImage = `${siteUrl}/og-image.jpg`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  "@id": `${siteUrl}/#business`,
  name: businessName,
  description: pageDesc,
  url: siteUrl,
  image: ogImage,
  logo: `${siteUrl}/icon-512.png`,
  telephone: `+504 ${phone}`,
  email,
  priceRange: "$$",
  founder: { "@type": "Person", name: "Edgar García" },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Tegucigalpa",
    addressRegion: "Francisco Morazán",
    addressCountry: "HN",
  },
  areaServed: { "@type": "Country", name: "Honduras" },
  sameAs: [instagram, facebook],
};
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={siteUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#faf5ec" />

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={businessName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="EG Eventos — Wedding & Events Planners" />
    <meta property="og:locale" content="es_LA" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="preload" as="image" href="/about-founder.webp" fetchpriority="high" />
    <link rel="preload" as="image" href="/logo.webp" fetchpriority="high" />
    <link rel="preload" as="image" href="/hero-bodas.webp" />
    <link rel="preload" as="image" href="/hero-graduaciones.webp" />
    <link rel="preload" as="image" href="/hero-sociales.webp" />
  </head>

  <body>
    <main class="ss-page">
      <nav id="ss-mobile-menu" class="ss-mobile-menu" aria-label="Menú de navegación">
        <button class="ss-menu-close" type="button" aria-label="Cerrar menú">&times;</button>
        <ul class="ss-mobile-menu-links">
          <li><a href="#servicios">Servicios</a></li>
          <li><a href="#galeria">Galería</a></li>
          <li><a href="#sobre">Sobre mí</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
        <a href={whatsappLink} class="ss-button ss-button-primary ss-mobile-menu-cta">
          Cotizar evento
        </a>
      </nav>

      <div class="ss-stickybar" id="ss-stickybar">
        <a href="#" class="ss-stickybar-logo">EG Eventos</a>
        <nav class="ss-stickybar-links">
          <a href="#servicios">Servicios</a>
          <a href="#galeria">Galería</a>
          <a href="#sobre">Sobre mí</a>
          <a href="#contacto">Contacto</a>
        </nav>
        <a href={whatsappLink} class="ss-button ss-button-primary ss-stickybar-cta">
          Cotizar evento
        </a>
        <button class="ss-menu-toggle ss-menu-toggle-sticky" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="ss-mobile-menu">
          <span></span><span></span><span></span>
        </button>
      </div>

      <section class="ss-cover" aria-label="Portada">
        <div class="ss-cover-photo" aria-hidden="true"></div>
        <div class="ss-cover-scrim" aria-hidden="true"></div>
        <div class="ss-cover-grain" aria-hidden="true"></div>

        <div class="ss-cover-inner">
          <a href="#inicio" class="ss-cover-logo" aria-label="EG Eventos">
            <img src="/logo.webp" alt="EG Eventos" width="200" height="211" fetchpriority="high" decoding="async" />
          </a>

          <div class="ss-cover-bottom">
            <div class="ss-cover-headline">
              <p class="ss-cover-eyebrow">EG Eventos</p>
              <h1 class="ss-display-title ss-cover-title">
                Wedding &amp; Event Planner
              </h1>
              <p class="ss-cover-name">Edgar García &middot; Fundador</p>
            </div>
          </div>
        </div>
      </section>

      <section id="inicio" class="ss-hero">
        <div class="ss-hero-photo" aria-hidden="true"></div>
        <div class="ss-hero-scrim" aria-hidden="true"></div>

        <header class="ss-header">
          <button class="ss-menu-toggle ss-menu-toggle-hero" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="ss-mobile-menu">
            <span></span><span></span><span></span>
          </button>
          <div class="ss-topbar">
            <a href="#" class="ss-logo" aria-label="EG Eventos">
              <img src="/logo.webp" alt="EG Eventos" class="ss-logo-img" width="200" height="211" fetchpriority="high" decoding="async" />
            </a>
          </div>

          <nav class="ss-nav">
            <div class="ss-nav-links">
              <a href="#servicios">Servicios</a>
              <a href="#galeria">Galería</a>
              <a href="#sobre">Sobre mí</a>
              <a href="#contacto">Contacto</a>
            </div>

            <a href={whatsappLink} class="ss-button ss-button-primary ss-nav-cta">
              Cotizar evento
            </a>
          </nav>
        </header>

        <div class="ss-hero-welcome">
          <p class="ss-hero-eyebrow">
            <span class="ss-hero-eyebrow-line" aria-hidden="true"></span>
            Wedding &amp; Event Planner
          </p>

          <h1 class="ss-display-title ss-hero-title">
            Bodas y eventos
            <em>que se sienten tuyos</em>
          </h1>

          <p class="ss-hero-lead">
            Del concepto al último brindis, cuidamos cada detalle para que
            tú solo vivas el momento.
          </p>

          <div class="ss-hero-actions">
            <a href={whatsappLink} class="ss-button ss-button-primary">
              Cotizar evento
            </a>

            <a href="#servicios" class="ss-hero-link">Ver servicios</a>
          </div>
        </div>
      </section>

      <section id="servicios" class="ss-services">
        <div class="ss-services-glow"></div>

        <div class="ss-services-inner">
          <header class="ss-services-header">
            <span class="ss-services-rule"></span>
            <h2 class="ss-display-title ss-services-title">
              Diseñamos cada detalle de tu celebración
            </h2>
            <p class="ss-services-intro">
              Un servicio integral que cuida la planificación, la estética y la
              experiencia de tu evento de principio a fin.
            </p>
          </header>

          <ul class="ss-services-grid">
            <li class="ss-service">
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Planificación de eventos</h3>
              <p class="ss-service-text">
                Planificamos cada detalle de tu evento con pasión y profesionalismo.
                Nuestros servicios integrales contemplan la estética y la logística
                de tu evento, creando experiencias únicas.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Decoración personalizada</h3>
              <p class="ss-service-text">
                Decoramos cada detalle con exclusividad, armonizando colores, texturas
                y cada elemento, para dar vida a la celebración que imaginas.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Montajes elegantes</h3>
              <p class="ss-service-text">
                La elegancia de nuestros montajes transmite un ambiente exclusivo y
                sofisticado, creando una experiencia visual inolvidable.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Centros de mesa exclusivos</h3>
              <p class="ss-service-text">
                Nuestros centros de mesa aportan estilo y personalidad a cada mesa,
                logrando la elegancia y el estilo deseado.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Ambientaciones temáticas</h3>
              <p class="ss-service-text">
                Atmósferas completas creadas con conceptos únicos, logrando que tu
                evento sea un momento verdaderamente especial.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Atención profesional</h3>
              <p class="ss-service-text">
                Nuestro equipo combina experiencia, creatividad y atención personalizada
                para ofrecer un servicio cercano y de calidad. Creamos ambientes para
                cada ocasión.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Catering y banquete</h3>
              <p class="ss-service-text">
                Servicio de catering y banquete para tu evento, con un equipo de meseros
                que atiende cada mesa con esmero de principio a fin.
              </p>
            </li>

          </ul>

          <div class="ss-services-cta">
            <p>Cada evento es único. Cuéntanos cómo imaginas el tuyo.</p>
            <a href={whatsappLink} class="ss-button ss-button-primary">
              Cotizar evento
            </a>
          </div>
        </div>
      </section>

      <section id="tipos" class="ss-events">
        <div class="ss-events-header">
          <p class="ss-eyebrow">
            <span class="ss-eyebrow-line"></span>
            Tipos de eventos
          </p>
          <h2 class="ss-display-title ss-events-title">
            Creamos ambientes para cada ocasión
          </h2>
          <p class="ss-events-intro">
            Desde la intimidad de una celebración privada hasta la escala de un
            evento empresarial, adaptamos cada montaje al carácter del momento.
          </p>
        </div>

        <div class="ss-bands">
          <article class="ss-band ss-band-bodas">
            <div class="ss-band-content">
              <span class="ss-band-index">01</span>
              <h3 class="ss-band-name">Bodas</h3>
              <p class="ss-band-text">
                Ceremonias y recepciones diseñadas para el día más importante.
              </p>
            </div>
          </article>

          <article class="ss-band ss-band-graduaciones">
            <div class="ss-band-content">
              <span class="ss-band-index">02</span>
              <h3 class="ss-band-name">Graduaciones</h3>
              <p class="ss-band-text">
                Celebramos los logros que marcan el final de una etapa.
              </p>
            </div>
          </article>

          <article class="ss-band ss-band-sociales">
            <div class="ss-band-content">
              <span class="ss-band-index">03</span>
              <h3 class="ss-band-name">Celebraciones sociales</h3>
              <p class="ss-band-text">
                Quince años, baby showers, bautizos y fiestas temáticas pensadas para los tuyos.
              </p>
            </div>
          </article>

          <article class="ss-band ss-band-empresariales">
            <div class="ss-band-content">
              <span class="ss-band-index">04</span>
              <h3 class="ss-band-name">Eventos empresariales</h3>
              <p class="ss-band-text">
                Imagen, protocolo y logística cuidada para tu empresa.
              </p>
            </div>
          </article>
        </div>
      </section>

      <section id="galeria" class="ss-gallery">
        <div class="ss-gallery-inner">
          <header class="ss-gallery-header">
            <h2 class="ss-display-title ss-gallery-title">
              Detalles que transforman momentos en recuerdos
            </h2>
            <p class="ss-gallery-intro">
              Una muestra de montajes, decoración y ambientaciones creadas para
              celebraciones reales.
            </p>
          </header>

          <p class="ss-gallery-hint" aria-hidden="true">Desliza para ver más &rarr;</p>

          <div class="ss-gallery-grid">
            <figure class="ss-gallery-item">
              <div class="ss-gallery-frame">
                <div class="ss-gallery-media ss-shot-7"></div>
              </div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Graduación</span>
                <span class="ss-gallery-desc">Montaje del salón</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-frame">
                <div class="ss-gallery-media ss-shot-4"></div>
              </div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Decoración</span>
                <span class="ss-gallery-desc">Temática masquerade</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-frame">
                <div class="ss-gallery-media ss-shot-1"></div>
              </div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Bodas</span>
                <span class="ss-gallery-desc">Montaje completo</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-frame">
                <div class="ss-gallery-media ss-shot-8"></div>
              </div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Centros de mesa</span>
                <span class="ss-gallery-desc">Detalle en verde salvia</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-frame">
                <div class="ss-gallery-media ss-shot-5"></div>
              </div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Graduaciones</span>
                <span class="ss-gallery-desc">Centro de mesa</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-frame">
                <div class="ss-gallery-media ss-shot-3"></div>
              </div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Celebración</span>
                <span class="ss-gallery-desc">Momentos reales</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-frame">
                <div class="ss-gallery-media ss-shot-9"></div>
              </div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Decoración</span>
                <span class="ss-gallery-desc">Centro de mesa</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-frame">
                <div class="ss-gallery-media ss-shot-6"></div>
              </div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Decoración</span>
                <span class="ss-gallery-desc">Mesas de coctel</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-frame">
                <div class="ss-gallery-media ss-shot-2"></div>
              </div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Centros de mesa</span>
                <span class="ss-gallery-desc">Piezas a medida</span>
              </figcaption>
            </figure>
          </div>

          <a href="#redes" class="ss-gallery-more">Ver más momentos</a>
        </div>
      </section>

      <section id="sobre" class="ss-about">
        <div class="ss-about-inner">
          <div class="ss-about-figure">
            <div class="ss-about-backdrop" aria-hidden="true"></div>
            <img
              class="ss-about-portrait"
              src="/founder-sobre.webp"
              alt="Edgar García, fundador de EG Eventos"
              width="886"
              height="1500"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="ss-about-body">
            <p class="ss-about-eyebrow">El fundador</p>
            <h2 class="ss-display-title ss-about-title">
              La pasión detrás de cada evento
            </h2>
            <p class="ss-about-text">
              Detrás de cada montaje hay una persona obsesionada con los detalles.
              Fundé EG Eventos con una idea simple: que cada celebración se sienta
              única, cálida y sin estrés para quien la vive. Acompaño a cada cliente
              desde la primera idea hasta el último brindis, cuidando su historia
              como si fuera la mía.
            </p>
            <p class="ss-about-signature">Edgar García · Fundador de EG Eventos</p>
            <p class="ss-about-tagline">Wedding &amp; Events Planners</p>
            <a href="#contacto" class="ss-button ss-button-secondary ss-about-cta">
              Cotizar evento
            </a>
          </div>
        </div>
      </section>

      <section id="filosofia" class="ss-values">
        <div class="ss-values-inner">
          <header class="ss-values-header">
            <h2 class="ss-display-title ss-values-title">
              Lo que nos mueve
            </h2>
            <p class="ss-values-intro">
              Trabajamos con una idea clara de quiénes somos y hacia dónde vamos,
              y con principios que se notan en cada evento que entregamos.
            </p>
          </header>

          <div class="ss-values-statements">
            <article class="ss-statement">
              <h3 class="ss-statement-label">Misión</h3>
              <p class="ss-statement-text">
                Brindar un excelente y completo servicio en organización de eventos,
                donde el compromiso y el alto grado de servicio al cliente son la
                garantía para lograr de su evento un momento inolvidable.
              </p>
            </article>

            <article class="ss-statement">
              <h3 class="ss-statement-label">Visión</h3>
              <p class="ss-statement-text">
                Ser líder del mercado de organizadores de eventos, reconocidos por
                nuestro profesionalismo, honestidad, vocación de servicio y compromiso
                con los objetivos de nuestros clientes, teniendo como punto de partida
                la satisfacción de nuestro mercado meta.
              </p>
            </article>
          </div>

          <div class="ss-values-principles">
            <span class="ss-values-principles-label">Nuestros valores</span>
            <ul class="ss-values-list">
              <li>Cumplimiento</li>
              <li>Responsabilidad</li>
              <li>Respeto</li>
              <li>Actitud al servicio</li>
              <li>Mejoramiento continuo</li>
              <li>Trabajo en equipo</li>
              <li>Responsabilidad social</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="servicio" class="ss-crew">
        <div class="ss-crew-inner">
          <div class="ss-crew-left">
          <div class="ss-crew-media">
            <div class="ss-crew-col ss-crew-col-main">
              <figure class="ss-crew-fig">
                <img src="/crew-serving.webp" alt="Mesero de EG Eventos sirviendo durante el evento" loading="lazy" decoding="async" width="1400" height="933" />
              </figure>
              
            </div>
            <div class="ss-crew-col ss-crew-col-side">
              
              <figure class="ss-crew-fig ss-crew-fig-top">
                <img src="/crew-portrait.webp" alt="Mesero de EG Eventos" loading="lazy" decoding="async" width="900" height="1350" />
              </figure>
            </div>
          </div>

          <div class="ss-crew-strip">
            <figure class="ss-crew-thumb">
              <img src="/crew-detail-1.webp" alt="Chef de EG Eventos sirviendo el banquete" loading="lazy" decoding="async" width="520" height="390" />
            </figure>
            <figure class="ss-crew-thumb">
              <img src="/crew-detail-2.webp" alt="Meseros de EG Eventos con las charolas del servicio" loading="lazy" decoding="async" width="520" height="390" />
            </figure>
            <figure class="ss-crew-thumb">
              <img src="/crew-detail-3.webp" alt="Mesera de EG Eventos sirviendo bocadillos" loading="lazy" decoding="async" width="520" height="390" />
            </figure>
          </div>
          </div>

          <div class="ss-crew-content">
            <h2 class="ss-display-title ss-crew-title">
              No solo lo planeamos: lo servimos
            </h2>
            <p class="ss-crew-intro">
              Meseros, chef y montaje profesional para que tu única tarea sea
              disfrutar. Nuestro equipo atiende a cada invitado con la misma
              dedicación con la que diseñamos tu evento.
            </p>

            <ul class="ss-crew-list">
              <li>
                <span class="ss-crew-item-name">Meseros profesionales</span>
                <span class="ss-crew-item-text">Personal uniformado y capacitado para atender cada mesa.</span>
              </li>
              <li>
                <span class="ss-crew-item-name">Chef y banquete</span>
                <span class="ss-crew-item-text">Menús y bocadillos preparados y servidos al momento.</span>
              </li>
              <li>
                <span class="ss-crew-item-name">Montaje y vajilla</span>
                <span class="ss-crew-item-text">Mesas, mantelería, vajilla y centros de mesa listos.</span>
              </li>
              <li>
                <span class="ss-crew-item-name">Coordinación en sitio</span>
                <span class="ss-crew-item-text">Dirigimos los tiempos para que todo fluya sin que lo notes.</span>
              </li>
            </ul>

            <a href={whatsappLink} class="ss-button ss-button-primary ss-crew-cta">
              Cotizar tu evento
            </a>
          </div>
        </div>
      </section>

      <section id="redes" class="ss-social">
        <div class="ss-social-inner">
          <header class="ss-social-header">
            <h2 class="ss-display-title ss-social-title">
              Más momentos en <em>@egeventos01</em>
            </h2>
            <p class="ss-social-intro">
              Inspiración, montajes y el detrás de cámaras de nuestras celebraciones.
            </p>
          </header>

          <div class="ss-social-grid">
            <a class="ss-social-item ss-shot-1" href={instagram} target="_blank" rel="noopener" aria-label="Ver en Instagram"></a>
            <a class="ss-social-item ss-shot-2" href={instagram} target="_blank" rel="noopener" aria-label="Ver en Instagram"></a>
