---
import '../styles/global.css';

const businessName = "EGEVENTOS";
const whatsapp = "50499999999";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Cobertura profesional de eventos con fotografía, video y contenido para redes sociales." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{businessName} | Eventos y Producción Audiovisual</title>
  </head>

  <body>
    <main class="min-h-screen bg-neutral-950 text-white">
      <section class="px-6 py-8 md:px-16">
        <nav class="mx-auto flex max-w-6xl items-center justify-between">
          <div class="text-lg font-bold tracking-wide">{businessName}</div>

          <a 
            href={`https://wa.me/${whatsapp}`}
            class="rounded-full bg-white px-5 py-2 text-sm font-semibold text-black transition hover:scale-105"
          >
            Cotizar evento
          </a>
        </nav>

        <div class="mx-auto grid max-w-6xl items-center gap-12 py-20 md:grid-cols-2 md:py-28">
          <div>
            <p class="mb-4 text-sm uppercase tracking-[0.3em] text-neutral-400">
              Eventos · Fotografía · Video
            </p>

            <h1 class="text-5xl font-black leading-tight md:text-7xl">
              Convertimos eventos en contenido que vende.
            </h1>

            <p class="mt-6 max-w-xl text-lg leading-8 text-neutral-300">
              Cobertura profesional para eventos sociales, empresariales y promocionales. 
              Creamos fotografías, reels y videos listos para publicar en redes sociales.
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <a 
                href={`https://wa.me/${whatsapp}`}
                class="rounded-full bg-white px-7 py-3 text-center font-semibold text-black transition hover:scale-105"
              >
                Agendar cobertura
              </a>

              <a 
                href="#servicios"
                class="rounded-full border border-white/20 px-7 py-3 text-center font-semibold text-white transition hover:bg-white/10"
              >
                Ver servicios
              </a>
            </div>
          </div>

          <div class="rounded-[2rem] border border-white/10 bg-white/5 p-4 shadow-2xl">
            <div class="flex aspect-[4/5] items-end rounded-[1.5rem] bg-neutral-800 p-6">
              <div class="rounded-2xl bg-black/60 p-4 backdrop-blur">
                <p class="text-sm text-neutral-300">Contenido visual premium</p>
                <p class="text-2xl font-bold">Fotos + Reels + Video</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="servicios" class="px-6 py-20 md:px-16">
        <div class="mx-auto max-w-6xl">
          <p class="text-sm uppercase tracking-[0.3em] text-neutral-500">Servicios</p>
          <h2 class="mt-3 text-4xl font-black md:text-5xl">
            Todo lo necesario para promocionar tu evento.
          </h2>

          <div class="mt-10 grid gap-5 md:grid-cols-3">
            <article class="rounded-3xl border border-white/10 bg-white/5 p-7">
              <h3 class="text-2xl font-bold">Fotografía</h3>
              <p class="mt-3 text-neutral-300">
                Capturamos los mejores momentos del evento con edición lista para redes.
              </p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-white/5 p-7">
              <h3 class="text-2xl font-bold">Video publicitario</h3>
              <p class="mt-3 text-neutral-300">
                Creamos reels, teasers y resúmenes visuales para Instagram, Facebook y TikTok.
              </p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-white/5 p-7">
              <h3 class="text-2xl font-bold">Contenido para redes</h3>
              <p class="mt-3 text-neutral-300">
                Entregamos piezas optimizadas para atraer clientes y mostrar la experiencia.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="px-6 py-20 md:px-16">
        <div class="mx-auto max-w-5xl rounded-[2rem] border border-white/10 bg-white p-10 text-center text-black md:p-16">
          <h2 class="text-4xl font-black md:text-5xl">
            ¿Listo para cubrir tu próximo evento?
          </h2>

          <p class="mx-auto mt-5 max-w-2xl text-lg text-neutral-700">
            Hablemos de tu evento y creemos contenido visual que ayude a promocionarlo mejor.
          </p>

          <a 
            href={`https://wa.me/${whatsapp}`}
            class="mt-8 inline-block rounded-full bg-black px-8 py-4 font-semibold text-white transition hover:scale-105"
          >
            Escribir por WhatsApp
          </a>
        </div>
      </section>

      <footer class="border-t border-white/10 px-6 py-8 text-center text-sm text-neutral-500">
        <p>© 2026 {businessName}. Desarrollado por Scale Studio.</p>
      </footer>
    </main>
  </body>
</html>	