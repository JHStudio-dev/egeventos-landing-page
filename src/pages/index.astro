---
import '../styles/global.css';

const businessName = "EG Eventos";
const whatsapp = "50489123226";
const phone = "8912-3226";
const email = "eventos.eg@hotmail.com";
const instagram = "https://www.instagram.com/egeventos01";
const facebook = "https://www.facebook.com/egevetos";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Planificación, decoración y coordinación de eventos elegantes. Bodas, graduaciones y celebraciones sociales cuidadas en cada detalle."
    />
    <title>{businessName} | Wedding & Events Planners</title>
  </head>

  <body>
    <main class="ss-page">
      <div class="ss-stickybar" id="ss-stickybar">
        <a href="#" class="ss-stickybar-logo">EG Eventos</a>
        <nav class="ss-stickybar-links">
          <a href="#servicios">Servicios</a>
          <a href="#galeria">Galería</a>
          <a href="#sobre">Sobre mí</a>
          <a href="#contacto">Contacto</a>
        </nav>
        <a href={`https://wa.me/${whatsapp}`} class="ss-button ss-button-primary ss-stickybar-cta">
          Cotizar evento
        </a>
      </div>

      <section class="ss-hero">
        <div class="ss-hero-pattern"></div>
        <div class="ss-hero-glow ss-hero-glow-one"></div>
        <div class="ss-hero-glow ss-hero-glow-two"></div>

        <header class="ss-header">
          <div class="ss-topbar">
            <a href="#" class="ss-logo" aria-label="EG Eventos">
              <img src="/logo.png" alt="EG Eventos" class="ss-logo-img" width="200" height="211" />
            </a>
          </div>

          <nav class="ss-nav">
            <div class="ss-nav-links">
              <a href="#servicios">Servicios</a>
              <a href="#galeria">Galería</a>
              <a href="#sobre">Sobre mí</a>
              <a href="#contacto">Contacto</a>
            </div>

            <a href={`https://wa.me/${whatsapp}`} class="ss-button ss-button-primary ss-nav-cta">
              Cotizar evento
            </a>
          </nav>
        </header>

        <div class="ss-hero-grid">
          <div class="ss-hero-content">
            <p class="ss-eyebrow">
              <span class="ss-eyebrow-line"></span>
              Wedding &amp; Events Planners
            </p>

            <h1 class="ss-display-title ss-hero-title">
              Hacemos de cada evento
              <em>un recuerdo inolvidable</em>
            </h1>

            <p class="ss-body-text ss-hero-text">
              Planificación, decoración y coordinación de eventos elegantes.
              De bodas a graduaciones y celebraciones sociales, cuidamos cada
              detalle por ti.
            </p>

            <div class="ss-hero-actions">
              <a href={`https://wa.me/${whatsapp}`} class="ss-button ss-button-primary">
                Cotizar evento
              </a>

              <a href="#servicios" class="ss-button ss-button-secondary">
                Ver servicios
              </a>
            </div>
          </div>

          <div class="ss-hero-showcase" aria-label="Tipos de eventos">
            <article class="ss-arch-card ss-arch-card-left">
              <div class="ss-arch-shell">
                <div class="ss-arch-rim">
                  <div class="ss-arch-image ss-photo-graduaciones">
                    <span class="ss-arch-label">Graduaciones</span>
                  </div>
                </div>
                <div class="ss-arch-plinth">
                  <div class="ss-arch-plinth-top"></div>
                  <p>Graduaciones</p>
                </div>
              </div>
            </article>

            <article class="ss-arch-card ss-arch-card-feature">
              <div class="ss-arch-shell">
                <div class="ss-arch-rim">
                  <div class="ss-arch-image ss-photo-bodas">
                    <span class="ss-arch-label">Bodas</span>
                  </div>
                </div>
                <div class="ss-arch-plinth">
                  <div class="ss-arch-plinth-top"></div>
                  <p>Bodas</p>
                </div>
              </div>
            </article>

            <article class="ss-arch-card ss-arch-card-right">
              <div class="ss-arch-shell">
                <div class="ss-arch-rim">
                  <div class="ss-arch-image ss-photo-sociales">
                    <span class="ss-arch-label">Sociales</span>
                  </div>
                </div>
                <div class="ss-arch-plinth">
                  <div class="ss-arch-plinth-top"></div>
                  <p>Sociales</p>
                </div>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="servicios" class="ss-services">
        <div class="ss-services-glow"></div>

        <div class="ss-services-inner">
          <header class="ss-services-header">
            <span class="ss-services-rule"></span>
            <h2 class="ss-display-title ss-services-title">
              Diseñamos cada detalle de tu celebración
            </h2>
            <p class="ss-services-intro">
              Un servicio integral que cuida la planificación, la estética y la
              experiencia de tu evento de principio a fin.
            </p>
          </header>

          <ul class="ss-services-grid">
            <li class="ss-service">
              <span class="ss-service-num">01</span>
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Planificación de eventos</h3>
              <p class="ss-service-text">
                Coordinamos cada etapa, desde la primera idea hasta el último invitado.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-num">02</span>
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Decoración personalizada</h3>
              <p class="ss-service-text">
                Diseños a la medida de tu historia, tu estilo y tu celebración.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-num">03</span>
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Montajes elegantes</h3>
              <p class="ss-service-text">
                Estructuras, mobiliario e iluminación montados con precisión y buen gusto.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-num">04</span>
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Centros de mesa exclusivos</h3>
              <p class="ss-service-text">
                Piezas florales y detalles que hacen de cada mesa una protagonista.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-num">05</span>
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Ambientaciones temáticas</h3>
              <p class="ss-service-text">
                Atmósferas completas creadas alrededor de un concepto único.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-num">06</span>
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Atención profesional</h3>
              <p class="ss-service-text">
                Un equipo pendiente de cada detalle para que tú solo disfrutes.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-num">07</span>
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Alquiler de sillas y mesas</h3>
              <p class="ss-service-text">
                Mobiliario montado y listo para recibir a todos tus invitados.
              </p>
            </li>

            <li class="ss-service">
              <span class="ss-service-num">08</span>
              <span class="ss-service-line"></span>
              <h3 class="ss-service-name">Cristalería</h3>
              <p class="ss-service-text">
                Copas y detalles de mesa para servir cada momento con estilo.
              </p>
            </li>
          </ul>

          <div class="ss-services-cta">
            <p>Cada evento es único. Cuéntanos cómo imaginas el tuyo.</p>
            <a href={`https://wa.me/${whatsapp}`} class="ss-button ss-button-primary">
              Cotizar evento
            </a>
          </div>
        </div>
      </section>

      <section id="tipos" class="ss-events">
        <div class="ss-events-header">
          <p class="ss-eyebrow">
            <span class="ss-eyebrow-line"></span>
            Tipos de eventos
          </p>
          <h2 class="ss-display-title ss-events-title">
            Creamos ambientes para cada ocasión
          </h2>
          <p class="ss-events-intro">
            Desde la intimidad de una celebración privada hasta la escala de un
            evento empresarial, adaptamos cada montaje al carácter del momento.
          </p>
        </div>

        <div class="ss-bands">
          <article class="ss-band ss-band-bodas">
            <div class="ss-band-content">
              <span class="ss-band-index">01</span>
              <h3 class="ss-band-name">Bodas</h3>
              <p class="ss-band-text">
                Ceremonias y recepciones diseñadas para el día más importante.
              </p>
            </div>
          </article>

          <article class="ss-band ss-band-graduaciones">
            <div class="ss-band-content">
              <span class="ss-band-index">02</span>
              <h3 class="ss-band-name">Graduaciones</h3>
              <p class="ss-band-text">
                Celebramos los logros que marcan el final de una etapa.
              </p>
            </div>
          </article>

          <article class="ss-band ss-band-sociales">
            <div class="ss-band-content">
              <span class="ss-band-index">03</span>
              <h3 class="ss-band-name">Celebraciones sociales</h3>
              <p class="ss-band-text">
                Quince años, baby showers, bautizos y fiestas temáticas pensadas para los tuyos.
              </p>
            </div>
          </article>

          <article class="ss-band ss-band-empresariales">
            <div class="ss-band-content">
              <span class="ss-band-index">04</span>
              <h3 class="ss-band-name">Eventos empresariales</h3>
              <p class="ss-band-text">
                Imagen, protocolo y logística cuidada para tu empresa.
              </p>
            </div>
          </article>
        </div>
      </section>

      <section id="galeria" class="ss-gallery">
        <div class="ss-gallery-inner">
          <header class="ss-gallery-header">
            <h2 class="ss-display-title ss-gallery-title">
              Detalles que transforman momentos en recuerdos
            </h2>
            <p class="ss-gallery-intro">
              Una muestra de montajes, decoración y ambientaciones creadas para
              celebraciones reales.
            </p>
          </header>

          <div class="ss-gallery-grid">
            <figure class="ss-gallery-item">
              <div class="ss-gallery-media ss-shot-1"></div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Bodas</span>
                <span class="ss-gallery-desc">Recepción de gala</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-media ss-shot-2"></div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Decoración</span>
                <span class="ss-gallery-desc">Ambientación floral</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-media ss-shot-3"></div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Centros de mesa</span>
                <span class="ss-gallery-desc">Piezas a medida</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-media ss-shot-4"></div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Graduaciones</span>
                <span class="ss-gallery-desc">Celebración formal</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-media ss-shot-5"></div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Ambientación</span>
                <span class="ss-gallery-desc">Montaje temático</span>
              </figcaption>
            </figure>
            <figure class="ss-gallery-item">
              <div class="ss-gallery-media ss-shot-6"></div>
              <figcaption class="ss-gallery-caption">
                <span class="ss-gallery-cat">Montajes</span>
                <span class="ss-gallery-desc">Escenografía completa</span>
              </figcaption>
            </figure>
          </div>

          <a href="#redes" class="ss-gallery-more">Ver más momentos</a>
        </div>
      </section>

      <section id="sobre" class="ss-about">
        <div class="ss-about-inner">
          <div class="ss-about-portrait">
            <div class="ss-about-photo ss-photo-founder"></div>
          </div>

          <div class="ss-about-content">
            <h2 class="ss-display-title ss-about-title">
              La pasión detrás de cada evento
            </h2>
            <p class="ss-about-text">
              Detrás de cada montaje hay una persona obsesionada con los detalles.
              Fundé EG Eventos con una idea simple: que cada celebración se sienta
              única, cálida y sin estrés para quien la vive. Acompaño a cada cliente
              desde la primera idea hasta el último brindis, cuidando su historia
              como si fuera la mía.
            </p>
            <p class="ss-about-signature">Edgar García · Fundador de EG Eventos</p>
            <a href="#contacto" class="ss-button ss-button-secondary ss-about-cta">
              Cotizar evento
            </a>
          </div>
        </div>
      </section>

      <section id="filosofia" class="ss-values">
        <div class="ss-values-inner">
          <header class="ss-values-header">
            <h2 class="ss-display-title ss-values-title">
              Lo que nos mueve
            </h2>
            <p class="ss-values-intro">
              Trabajamos con una idea clara de quiénes somos y hacia dónde vamos,
              y con principios que se notan en cada evento que entregamos.
            </p>
          </header>

          <div class="ss-values-statements">
            <article class="ss-statement">
              <h3 class="ss-statement-label">Misión</h3>
              <p class="ss-statement-text">
                Brindar un excelente y completo servicio en organización de eventos,
                donde el compromiso y el alto grado de servicio al cliente son la
                garantía para lograr de su evento un momento inolvidable.
              </p>
            </article>

            <article class="ss-statement">
              <h3 class="ss-statement-label">Visión</h3>
              <p class="ss-statement-text">
                Ser líder del mercado de organizadores de eventos, reconocidos por
                nuestro profesionalismo, honestidad, vocación de servicio y compromiso
                con los objetivos de nuestros clientes, teniendo como punto de partida
                la satisfacción de nuestro mercado meta.
              </p>
            </article>
          </div>

          <div class="ss-values-principles">
            <span class="ss-values-principles-label">Nuestros valores</span>
            <ul class="ss-values-list">
              <li>Cumplimiento</li>
              <li>Responsabilidad</li>
              <li>Respeto</li>
              <li>Actitud al servicio</li>
              <li>Mejoramiento continuo</li>
              <li>Trabajo en equipo</li>
              <li>Responsabilidad social</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="proceso" class="ss-process">
        <div class="ss-process-inner">
          <header class="ss-process-header">
            <h2 class="ss-display-title ss-process-title">
              Un proceso claro, de la idea al aplauso
            </h2>
            <p class="ss-process-intro">
              Te acompañamos en cada paso para que planear tu evento sea tan
              disfrutable como vivirlo.
            </p>
          </header>

          <ol class="ss-process-steps">
            <li class="ss-step">
              <span class="ss-step-num">01</span>
              <h3 class="ss-step-name">Consulta</h3>
              <p class="ss-step-text">
                Escuchamos tu idea, tu fecha y tu presupuesto para entender el evento que sueñas.
              </p>
            </li>
            <li class="ss-step">
              <span class="ss-step-num">02</span>
              <h3 class="ss-step-name">Diseño</h3>
              <p class="ss-step-text">
                Creamos el concepto, la paleta y el montaje a la medida de tu celebración.
              </p>
            </li>
            <li class="ss-step">
              <span class="ss-step-num">03</span>
              <h3 class="ss-step-name">Coordinación</h3>
              <p class="ss-step-text">
                Gestionamos proveedores, tiempos y cada detalle logístico por ti.
              </p>
            </li>
            <li class="ss-step">
              <span class="ss-step-num">04</span>
              <h3 class="ss-step-name">El gran día</h3>
              <p class="ss-step-text">
                Montamos y coordinamos todo para que tú solo te dediques a disfrutar.
              </p>
            </li>
          </ol>
        </div>
      </section>

      <section id="redes" class="ss-social">
        <div class="ss-social-inner">
          <header class="ss-social-header">
            <h2 class="ss-display-title ss-social-title">
              Más momentos en <em>@egeventos01</em>
            </h2>
            <p class="ss-social-intro">
              Inspiración, montajes y el detrás de cámaras de nuestras celebraciones.
            </p>
          </header>

          <div class="ss-social-grid">
            <a class="ss-social-item ss-shot-1" href={instagram} target="_blank" rel="noopener" aria-label="Ver en Instagram"></a>
            <a class="ss-social-item ss-shot-2" href={instagram} target="_blank" rel="noopener" aria-label="Ver en Instagram"></a>
            <a class="ss-social-item ss-shot-3" href={instagram} target="_blank" rel="noopener" aria-label="Ver en Instagram"></a>
            <a class="ss-social-item ss-shot-4" href={instagram} target="_blank" rel="noopener" aria-label="Ver en Instagram"></a>
            <a class="ss-social-item ss-shot-5" href={instagram} target="_blank" rel="noopener" aria-label="Ver en Instagram"></a>
            <a class="ss-social-item ss-shot-6" href={instagram} target="_blank" rel="noopener" aria-label="Ver en Instagram"></a>
          </div>

          <div class="ss-social-links">
            <a href={instagram} target="_blank" rel="noopener">Instagram</a>
            <a href={facebook} target="_blank" rel="noopener">Facebook</a>
          </div>
        </div>
      </section>

      <section id="contacto" class="ss-cta">
        <div class="ss-cta-card">
          <p class="ss-eyebrow ss-cta-eyebrow">
            <span class="ss-eyebrow-line"></span>
            Agenda tu evento
          </p>
          <h2 class="ss-display-title ss-cta-title">
            Hablemos de tu <em>próxima celebración</em>
          </h2>
          <p class="ss-cta-text">
            Cuéntanos tu idea y la convertimos en un evento inolvidable.
            Cotiza sin compromiso, te respondemos por WhatsApp.
          </p>

          <a href={`https://wa.me/${whatsapp}`} class="ss-button ss-button-primary ss-cta-button">
            Cotizar evento
          </a>

          <a href={`tel:+${whatsapp}`} class="ss-cta-phone">{phone}</a>
          <a href={`mailto:${email}`} class="ss-cta-email">{email}</a>

          <div class="ss-cta-socials">
            <a href={instagram} target="_blank" rel="noopener">Instagram</a>
            <a href={facebook} target="_blank" rel="noopener">Facebook</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="ss-footer">
      <div class="ss-footer-inner">
        <div class="ss-footer-brand">
          <a href="#" class="ss-logo" aria-label="EG Eventos">
              <img src="/logo.png" alt="EG Eventos" class="ss-logo-img" width="200" height="211" />
          </a>
          <p class="ss-footer-tagline">Wedding &amp; Events Planners</p>
          <p class="ss-footer-slogan">Nuestra pasión, tu satisfacción</p>
        </div>

        <nav class="ss-footer-col" aria-label="Secciones">
          <span class="ss-footer-label">Explora</span>
          <a href="#servicios">Servicios</a>
          <a href="#galeria">Galería</a>
          <a href="#contacto">Contacto</a>
        </nav>

        <div class="ss-footer-col">
          <span class="ss-footer-label">Contacto</span>
          <a href={`tel:+${whatsapp}`} class="ss-footer-phone">{phone}</a>
          <a href={`https://wa.me/${whatsapp}`}>WhatsApp</a>
          <a href={`mailto:${email}`}>{email}</a>
        </div>
      </div>

      <div class="ss-footer-bottom">
        <span>© 2026 EG Eventos</span>
        <span>Desarrollado por Scale Studio</span>
      </div>
    </footer>

    <script>
      const bar = document.getElementById("ss-stickybar");
      const hero = document.querySelector(".ss-hero");
      if (bar && hero) {
        const io = new IntersectionObserver(
          ([entry]) => bar.classList.toggle("is-visible", !entry.isIntersecting),
          { threshold: 0 }
        );
        io.observe(hero);
      }
    </script>
  </body>
</html>
